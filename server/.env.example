PORT=3001
TATUM_API_KEY=your_tatum_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
WALRUS_PUBLISHER_URL=https://publisher.walrus.storage

# PostgreSQL / Supabase Database persistence configuration
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://username:password@host:6543/postgres?pgbouncer=true"
# Direct connection to the database. Used for migrations
DIRECT_URL="postgres://username:password@host:5432/postgres"
